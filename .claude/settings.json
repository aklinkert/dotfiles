{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true",
    "ANTHROPIC_MODEL": "claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/alex/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/alex/.local/bin/statusline"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "prompt-improver@severity1-marketplace": false,
    "ralph-loop@claude-plugins-official": false,
    "dx@ykdojo": true,
    "product-management@knowledge-work-plugins": false,
    "ui-ux-pro-max@ui-ux-pro-max-skill": false,
    "terraform-provider-development@hashicorp": false,
    "gopls-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "sentry@claude-plugins-official": false,
    "auto-memory@severity1-marketplace": false,
    "playground@claude-plugins-official": false,
    "caveman@caveman": true,
    "atlassian@claude-plugins-official": false,
    "recap@annikalewis": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "annikalewis": {
      "source": {
        "source": "github",
        "repo": "annikalewis/claude-recap"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.84",
  "skipAutoPermissionPrompt": true,
  "$schema": "https://json.schemastore.org/claude-code-settings.json"
}
